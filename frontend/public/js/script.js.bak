/* From tunggakan-daftar-ulang.ejs */
function filterData() {
    var searchInput = document.getElementById("searchInput").value.toLowerCase();
    var statusInput = document.getElementById("statusInput").value.toLowerCase();
    var table = document.getElementById("dataTable");
    var tr = table.getElementsByTagName("tr");

    for (var i = 1; i < tr.length; i++) {
        var tdNama = tr[i].getElementsByTagName("td")[1]; // Nama is index 1
        var tdStatus = tr[i].getElementsByTagName("td")[7]; // Status is index 7
        if (tdNama && tdStatus) {
            var txtNama = tdNama.textContent || tdNama.innerText;
            var txtStatus = tdStatus.textContent || tdStatus.innerText;
            var matchNama = txtNama.toLowerCase().indexOf(searchInput) > -1;
            // For status, exactly matches the selected, or empty means all
            var matchStatus = statusInput === "" || txtStatus.toLowerCase().trim() === statusInput;
            
            if (matchNama && matchStatus) {
                tr[i].style.display = "";
            } else {
                tr[i].style.display = "none";
            }
        }       
    }
}

