/* From tagihan-daftar-ulang.ejs */
/* Enhanced Modal Styles */
.modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.6); overflow-y: auto; padding-top: 50px; padding-bottom: 50px; backdrop-filter: blur(4px); }
.modal-content { background-color: #ffffff; margin: 0 auto; padding: 35px 40px; border-radius: 12px; width: 90%; max-width: 650px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
.close-modal { color: #999; float: right; font-size: 32px; font-weight: 300; cursor: pointer; transition: color 0.3s; }
.close-modal:hover { color: #333; }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 2px solid #f0f0f0; padding-bottom: 20px; }

.modal-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 20px; }
.form-group-modal label { display: block; margin-bottom: 8px; font-weight: 600; color: #444; font-size: 14px; }
.form-input { width: 100%; padding: 12px 15px; border: 1px solid #ccc; border-radius: 6px; font-size: 15px; transition: border-color 0.3s, box-shadow 0.3s; box-sizing: border-box; }
.form-input:focus { border-color: #007bff; box-shadow: 0 0 5px rgba(0,123,255,0.3); outline: none; }
.form-input[readonly] { background-color: #f8f9fa; color: #6c757d; border-color: #dee2e6; cursor: not-allowed; }
.modal-footer { margin-top: 35px; text-align: right; border-top: 2px solid #f0f0f0; padding-top: 20px; }
.btn { padding: 10px 25px; font-weight: 600; border-radius: 6px; font-size: 15px; cursor: pointer; border: none; transition: background-color 0.3s; }
.btn-primary { background-color: #007bff; color: white; }
.btn-primary:hover { background-color: #0056b3; }
.btn-secondary { background-color: #6c757d; color: white; }
.btn-secondary:hover { background-color: #5a6268; }

/* From tagihan.ejs */
/* Enhanced Modal Styles */
.modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.6); overflow-y: auto; padding-top: 50px; padding-bottom: 50px; backdrop-filter: blur(4px); }
.modal-content { background-color: #ffffff; margin: 0 auto; padding: 35px 40px; border-radius: 12px; width: 90%; max-width: 650px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
.close-modal { color: #999; float: right; font-size: 32px; font-weight: 300; cursor: pointer; transition: color 0.3s; }
.close-modal:hover { color: #333; }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 2px solid #f0f0f0; padding-bottom: 20px; }

.modal-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 20px; }
.form-group-modal label { display: block; margin-bottom: 8px; font-weight: 600; color: #444; font-size: 14px; }
.form-input { width: 100%; padding: 12px 15px; border: 1px solid #ccc; border-radius: 6px; font-size: 15px; transition: border-color 0.3s, box-shadow 0.3s; box-sizing: border-box; }
.form-input:focus { border-color: #007bff; box-shadow: 0 0 5px rgba(0,123,255,0.3); outline: none; }
.form-input[readonly] { background-color: #f8f9fa; color: #6c757d; border-color: #dee2e6; cursor: not-allowed; }
.modal-footer { margin-top: 35px; text-align: right; border-top: 2px solid #f0f0f0; padding-top: 20px; }
.btn { padding: 10px 25px; font-weight: 600; border-radius: 6px; font-size: 15px; cursor: pointer; border: none; transition: background-color 0.3s; }
.btn-primary { background-color: #007bff; color: white; }
.btn-primary:hover { background-color: #0056b3; }
.btn-secondary { background-color: #6c757d; color: white; }
.btn-secondary:hover { background-color: #5a6268; }
