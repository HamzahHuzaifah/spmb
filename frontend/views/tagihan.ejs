<%- include('partials/header', { title: 'Tagihan Santri Baru', activePage: 'tagihan' }) %><link rel="stylesheet" href="/css/tagihan.css">
<div class="filter-bar">
    <form method="GET" action="/tagihan" class="filter-form">
        <input type="text" name="search" id="searchInput" class="form-control filter-search" placeholder="Cari Nama Santri..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
        <select name="pendidikan" id="satuanInput" class="form-control filter-select">
            <option value="">Semua Pendidikan</option>
            <option value="PAUDQu" <%= typeof pendidikanQuery !== 'undefined' && pendidikanQuery === 'PAUDQu' ? 'selected' : '' %>>PAUDQu</option>
            <option value="TPQ" <%= typeof pendidikanQuery !== 'undefined' && pendidikanQuery === 'TPQ' ? 'selected' : '' %>>TPQ</option>
            <option value="MDT" <%= typeof pendidikanQuery !== 'undefined' && pendidikanQuery === 'MDT' ? 'selected' : '' %>>MDT</option>
        </select>
        <button type="submit" class="btn btn-primary btn-submit-filter">Cari & Filter</button>
        <% if ((typeof searchQuery !== 'undefined' && searchQuery) || (typeof pendidikanQuery !== 'undefined' && pendidikanQuery)) { %>
            <a href="/tagihan" class="btn btn-secondary btn-reset-filter" style="text-decoration: none;">Reset</a>
        <% } %>
    </form>

    <div class="filter-actions">
        <button type="button" class="btn btn-secondary btn-print" onclick="window.print()">
            <i class="fas fa-print"></i> Cetak Tabel
        </button>
    </div>
</div>

<div class="table-container">
    <div class="table-header">
        <div class="table-title">Daftar Tagihan Berdasarkan Jalur</div>
    </div>
    
    <table id="dataTable">
        <thead>
            <tr>
                <th>Nama Santri</th>
                <th>Jalur Pendaftaran</th>
                <th>Satuan Pendidikan</th>
                <th>Formulir</th>
                <th>Uang Pangkal</th>
                <th>Perlengkapan</th>
                <th>Seragam</th>
                <th>SPP (Juli)</th>
                <th>Total Tagihan</th>
                <th>Terbayar</th>
                <th>Sisa Tagihan</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            <% if(tagihan && tagihan.length > 0) { %>
                <% tagihan.forEach(item => { %>
                <tr>
                    <td style="font-weight: 600;"><%= item.nama %></td>
                    <td>
                        <span class="badge <%= item.jalur === 'Regular' ? 'badge-info' : 'badge-warning' %>">
                            <%= item.jalur %>
                        </span>
                    </td>
                    <td><%= item.satuanPendidikan %></td>
                    <td>Rp <%= (item.formulir || 0).toLocaleString('id-ID') %></td>
                    <td>Rp <%= item.uangPangkal.toLocaleString('id-ID') %></td>
                    <td>Rp <%= item.perlengkapan.toLocaleString('id-ID') %></td>
                    <td>Rp <%= item.seragam.toLocaleString('id-ID') %></td>
                    <td>Rp <%= item.spp.toLocaleString('id-ID') %></td>
                    <td style="font-weight: bold; color: var(--primary);">Rp <%= item.totalTagihan.toLocaleString('id-ID') %></td>
                    <% 
                        let t = tunggakan.find(x => x.nama === item.nama);
                        let totalBayar = t ? t.totalBayar : 0;
                        let sisaBayar = t ? t.sisaBayar : item.totalTagihan;
                    %>
                    <td style="font-weight: bold; color: var(--success);">Rp <%= totalBayar.toLocaleString('id-ID') %></td>
                    <td style="font-weight: bold; color: var(--danger);">Rp <%= sisaBayar.toLocaleString('id-ID') %></td>
                    <td>
                        <button class="btn btn-secondary" style="padding: 5px 10px; font-size: 12px;" data-tagihan="<%= JSON.stringify(item) %>" onclick="openTagihanModal(this)">
                            <i class="fas fa-edit"></i> Edit
                        </button>
                    </td>
                </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="12" style="text-align: center;">Tidak ada data tagihan</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <!-- Pagination UI -->
    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px; padding: 10px 0; border-top: 1px solid #eee;">
            <div style="color: #666; font-size: 14px;">
                Menampilkan Halaman <strong><%= currentPage %></strong> dari <strong><%= totalPages %></strong> 
                (Total: <%= totalData %> Data)
            </div>
            <div style="display: flex; gap: 5px;">
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '' %><%= typeof pendidikanQuery !== 'undefined' && pendidikanQuery ? '&pendidikan='+pendidikanQuery : '' %>" class="btn btn-secondary" style="padding: 5px 12px; text-decoration: none;">&laquo; Prev</a>
                <% } %>

                <% 
                let startPage = Math.max(1, currentPage - 2);
                let endPage = Math.min(totalPages, currentPage + 2);
                for(let i = startPage; i <= endPage; i++) { 
                %>
                    <a href="?page=<%= i %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '' %><%= typeof pendidikanQuery !== 'undefined' && pendidikanQuery ? '&pendidikan='+pendidikanQuery : '' %>" 
                       class="btn <%= currentPage === i ? 'btn-primary' : 'btn-secondary' %>" 
                       style="padding: 5px 12px; text-decoration: none;">
                        <%= i %>
                    </a>
                <% } %>

                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '' %><%= typeof pendidikanQuery !== 'undefined' && pendidikanQuery ? '&pendidikan='+pendidikanQuery : '' %>" class="btn btn-secondary" style="padding: 5px 12px; text-decoration: none;">Next &raquo;</a>
                <% } %>
            </div>
        </div>
    <% } %>
</div>

<!-- Modal Edit Tagihan -->


<div id="tagihanModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
        <h2 style="color: var(--primary); margin: 0;">Edit Data Tagihan</h2>
        <span class="close-modal" onclick="closeTagihanModal()">&times;</span>
    </div>
    
    <form id="editTagihanForm" method="POST" action="" onsubmit="handleAjaxSubmitGlobal(event, this)">
        <div class="form-group-modal" style="margin-bottom: 20px;">
            <label>Nama Santri</label>
            <input type="text" id="m_nama" class="form-input" readonly>
        </div>

        <div class="modal-grid">
            <div class="form-group-modal">
                <label>Formulir (Rp)</label>
                <input type="number" name="formulir" id="m_formulir" class="form-input" required>
            </div>
            <div class="form-group-modal">
                <label>Uang Pangkal (Rp)</label>
                <input type="number" name="uangPangkal" id="m_uangPangkal" class="form-input" required>
            </div>
            <div class="form-group-modal">
                <label>Perlengkapan (Rp)</label>
                <input type="number" name="perlengkapan" id="m_perlengkapan" class="form-input" required>
            </div>
            <div class="form-group-modal">
                <label>Seragam (Rp)</label>
                <input type="number" name="seragam" id="m_seragam" class="form-input" required>
            </div>
            <div class="form-group-modal">
                <label>SPP (Juli) (Rp)</label>
                <input type="number" name="spp" id="m_spp" class="form-input" required>
            </div>
        </div>
        
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeTagihanModal()">Batal</button>
            <button type="submit" class="btn btn-primary" style="margin-left: 10px;">Simpan Perubahan</button>
        </div>
    </form>
  </div>
</div>



<%- include('partials/footer') %>
<script src="/js/tagihan.js"></script>
