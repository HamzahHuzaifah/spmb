<%- include('partials/header', { title: 'Tunggakan Daftar Ulang', activePage: 'tunggakan-daftar-ulang' }) %>

<div class="filter-bar">
    <form method="GET" action="/tunggakan-daftar-ulang" class="filter-form">
        <input type="text" name="search" id="searchInput" class="form-control filter-search" placeholder="Cari Nama Santri..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
        <select name="status" id="statusInput" class="form-control filter-select">
            <option value="">Semua Status Bayar</option>
            <option value="Lunas" <%= typeof statusQuery !== 'undefined' && statusQuery === 'Lunas' ? 'selected' : '' %>>Lunas</option>
            <option value="Belum Lunas" <%= typeof statusQuery !== 'undefined' && statusQuery === 'Belum Lunas' ? 'selected' : '' %>>Belum Lunas</option>
        </select>
        <button type="submit" class="btn btn-primary btn-submit-filter">Cari & Filter</button>
        <% if ((typeof searchQuery !== 'undefined' && searchQuery) || (typeof statusQuery !== 'undefined' && statusQuery)) { %>
            <a href="/tunggakan-daftar-ulang" class="btn btn-secondary btn-reset-filter" style="text-decoration: none;">Reset</a>
        <% } %>
    </form>

    <div class="filter-actions">
        <button type="button" class="btn btn-secondary btn-print" onclick="window.print()">
            <i class="fas fa-print"></i> Cetak Tabel
        </button>
    </div>
</div>

<div class="table-container">
    <div class="table-header">
        <div class="table-title">Daftar Tunggakan Santri Daftar Ulang</div>
    </div>
    
    <table id="dataTable">
        <thead>
            <tr>
                <th>No</th>
                <th>Nama Lengkap</th>
                <th>Lanjut Ke</th>
                <th>No Telepon</th>
                <th>Total Tagihan</th>
                <th>Total Bayar</th>
                <th>Sisa Bayar</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% if(tunggakan && tunggakan.length > 0) { %>
                <% tunggakan.forEach((item, index) => { %>
                <tr>
                    <td><%= index + 1 %></td>
                    <td style="font-weight: 600;"><%= item.nama %></td>
                    <td><span class="badge badge-info"><%= item.satuanPendidikan %></span></td>
                    <td><%= item.noTelepon %></td>
                    <td>Rp <%= item.totalTagihan.toLocaleString('id-ID') %></td>
                    <td>Rp <%= item.totalBayar.toLocaleString('id-ID') %></td>
                    <td style="color: var(--danger); font-weight: bold;">Rp <%= item.sisaBayar.toLocaleString('id-ID') %></td>
                    <td>
                        <span class="badge <%= item.status === 'Lunas' ? 'badge-success' : 'badge-danger' %>">
                            <%= item.status %>
                        </span>
                    </td>
                </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="8" style="text-align: center;">Tidak ada data tunggakan</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <!-- Pagination UI -->
    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px; padding: 10px 0; border-top: 1px solid #eee;">
            <div style="color: #666; font-size: 14px;">
                Menampilkan Halaman <strong><%= currentPage %></strong> dari <strong><%= totalPages %></strong> 
                (Total: <%= totalData %> Data)
            </div>
            <div style="display: flex; gap: 5px;">
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '' %><%= typeof statusQuery !== 'undefined' && statusQuery ? '&status='+statusQuery : '' %>" class="btn btn-secondary" style="padding: 5px 12px; text-decoration: none;">&laquo; Prev</a>
                <% } %>

                <% 
                let startPage = Math.max(1, currentPage - 2);
                let endPage = Math.min(totalPages, currentPage + 2);
                for(let i = startPage; i <= endPage; i++) { 
                %>
                    <a href="?page=<%= i %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '' %><%= typeof statusQuery !== 'undefined' && statusQuery ? '&status='+statusQuery : '' %>" 
                       class="btn <%= currentPage === i ? 'btn-primary' : 'btn-secondary' %>" 
                       style="padding: 5px 12px; text-decoration: none;">
                        <%= i %>
                    </a>
                <% } %>

                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '' %><%= typeof statusQuery !== 'undefined' && statusQuery ? '&status='+statusQuery : '' %>" class="btn btn-secondary" style="padding: 5px 12px; text-decoration: none;">Next &raquo;</a>
                <% } %>
            </div>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
<script src="/js/tunggakan-daftar-ulang.js"></script>
