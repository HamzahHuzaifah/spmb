<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + ' - ' : '' %>SPMB JIC
    </title>

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/images/Logo%20Madrasah.webp">

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- jQuery & Select2 -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <!-- Flatpickr (Custom Datepicker) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/id.js"></script>

    <!-- Custom CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            corePlugins: { preflight: false }
        }
    </script>
    <link rel="stylesheet" href="/css/style.css?v=2">
    
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>
    <!-- Page Loader Overlay -->
    <div id="pageLoader" class="page-loader-overlay">
        <div class="page-loader-spinner-container">
            <div class="page-loader-spinner"></div>
            <div class="page-loader-text">Memuat Halaman...</div>
        </div>
    </div>

    <div class="app-container">
        <!-- Sidebar Included from Parent -->
        <%- include('sidebar') %>

            <div class="main-content">
                <div class="topbar">
                    <div class="topbar-left">
                        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle Sidebar">
                            <i class="fas fa-bars"></i>
                        </button>
                        <div class="topbar-title">
                            <%= typeof title !=='undefined' ? title : 'Dashboard' %>
                        </div>
                    </div>
                    <div class="topbar-right">
                        <div class="user-profile-wrapper" style="position: relative;">
                            <div class="user-profile" id="userProfileDropdownBtn" style="display: flex; align-items: center; gap: 10px; cursor: pointer; padding: 5px 10px; border-radius: 6px; transition: background-color 0.2s;">
                                <span class="user-name"><%= typeof admin !== 'undefined' ? admin.nama : 'Admin MJIC' %></span>
                                <div class="avatar"><%= typeof admin !== 'undefined' && admin.nama ? admin.nama.charAt(0).toUpperCase() : 'A' %></div>
                                <i class="fas fa-chevron-down" style="font-size: 11px; color: #666; margin-left: 2px;"></i>
                            </div>
                            <!-- Dropdown Menu -->
                            <div class="profile-dropdown" id="profileDropdown" style="display: none; position: absolute; top: 100%; right: 0; margin-top: 8px; background: white; border: 1px solid #e2e8f0; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06); width: 200px; z-index: 1000; overflow: hidden;">
                                <a href="#" id="openAccountSettings" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; color: #1e293b; text-decoration: none; font-size: 14px; transition: background 0.15s; border-bottom: 1px solid #f1f5f9;">
                                    <i class="fas fa-cog" style="color: #64748b;"></i> Pengaturan Akun
                                </a>
                                <a href="/logout" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; color: #ef4444; text-decoration: none; font-size: 14px; transition: background 0.15s;">
                                    <i class="fas fa-sign-out-alt"></i> Keluar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- MODAL PENGATURAN AKUN & TAMBAH ADMIN -->
                <div id="adminSettingsModal" class="modal" style="display: none; position: fixed; z-index: 1050; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
                    <div class="modal-content" style="background-color: #fefefe; margin: auto; padding: 25px; border: 1px solid #e2e8f0; width: 90%; max-width: 500px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); box-sizing: border-box;">
                        <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #e2e8f0; padding-bottom: 15px; margin-bottom: 20px;">
                            <h3 style="margin: 0; font-size: 18px; font-weight: 600; color: #1e293b;">Pengaturan Akun & Admin</h3>
                            <span class="close-modal" id="closeAdminSettingsModal" style="color: #aaa; font-size: 28px; font-weight: bold; cursor: pointer; line-height: 1;">&times;</span>
                        </div>
                        
                        <!-- Tab Navigation -->
                        <div class="settings-tabs" style="display: flex; border-bottom: 1px solid #e2e8f0; margin-bottom: 20px; gap: 15px;">
                            <button class="settings-tab-btn active-tab" id="btnTabEditProfile" style="background: none; border: none; padding: 10px 5px; font-size: 14px; font-weight: 600; color: #059669; border-bottom: 2px solid #059669; cursor: pointer; transition: all 0.2s;">
                                <i class="fas fa-user-cog"></i> Edit Profil
                            </button>
                            <button class="settings-tab-btn" id="btnTabAddAdmin" style="background: none; border: none; padding: 10px 5px; font-size: 14px; font-weight: 600; color: #64748b; border-bottom: 2px solid transparent; cursor: pointer; transition: all 0.2s;">
                                <i class="fas fa-users"></i> Kelola Admin
                            </button>
                        </div>
                        
                        <!-- Tab 1: Edit Profile -->
                        <div class="settings-tab-content" id="tabEditProfile" style="display: block;">
                            <form id="formEditProfile" data-ajax="true" style="display: flex; flex-direction: column; gap: 15px;">
                                <div class="form-group-modal">
                                    <label for="profileNama" style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px; color: #475569;">Nama Lengkap</label>
                                    <input type="text" id="profileNama" name="nama_lengkap" class="form-input" value="<%= typeof admin !== 'undefined' ? admin.nama : '' %>" required style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box;">
                                </div>
                                <div class="form-group-modal">
                                    <label for="profileUsername" style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px; color: #475569;">Username</label>
                                    <input type="text" id="profileUsername" name="username" class="form-input" value="<%= typeof admin !== 'undefined' ? admin.username : '' %>" required style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box;">
                                </div>
                                <div class="form-group-modal">
                                    <label for="profilePasswordLama" style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px; color: #475569;">Password Lama (Wajib jika ubah password)</label>
                                    <input type="password" id="profilePasswordLama" name="password_lama" class="form-input" placeholder="Masukkan password lama..." style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box;">
                                </div>
                                <div class="form-group-modal">
                                    <label for="profilePasswordBaru" style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px; color: #475569;">Password Baru (Kosongkan jika tidak diubah)</label>
                                    <input type="password" id="profilePasswordBaru" name="password_baru" class="form-input" placeholder="Masukkan password baru..." style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box;">
                                </div>
                                <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 10px;">
                                    <button type="button" class="btn btn-secondary close-settings-modal-btn" style="padding: 10px 18px; border-radius: 6px; background-color: #94a3b8; border: none; color: white; cursor: pointer;">Batal</button>
                                    <button type="submit" class="btn btn-primary" style="padding: 10px 18px; border-radius: 6px; background-color: #059669; border: none; color: white; cursor: pointer;">Simpan Perubahan</button>
                                </div>
                            </form>
                        </div>
                        
                        <!-- Tab 2: Kelola Admin -->
                        <div class="settings-tab-content" id="tabAddAdmin" style="display: none;">
                            <div id="adminListWrapper">
                                <div style="display: flex; justify-content: flex-end; margin-bottom: 15px;">
                                    <button type="button" id="btnShowAddAdminForm" class="btn btn-primary" style="padding: 8px 15px; border-radius: 6px; background-color: #059669; border: none; color: white; cursor: pointer; font-size: 13px;"><i class="fas fa-plus"></i> Tambah Admin</button>
                                </div>
                                <div style="overflow-x: auto; max-height: 300px; border: 1px solid #e2e8f0; border-radius: 6px;">
                                    <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 13px;">
                                        <thead style="background-color: #f8fafc;">
                                            <tr style="border-bottom: 1px solid #e2e8f0;">
                                                <th style="padding: 10px; color: #475569;">No</th>
                                                <th style="padding: 10px; color: #475569;">Nama Lengkap</th>
                                                <th style="padding: 10px; color: #475569;">Username</th>
                                                <th style="padding: 10px; color: #475569; text-align: center;">Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody id="adminTableBody">
                                            <tr><td colspan="4" style="text-align: center; padding: 15px;">Memuat data...</td></tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <form id="formAddAdmin" data-ajax="true" style="display: none; flex-direction: column; gap: 15px;">
                                <div style="margin-bottom: 5px; font-weight: 600; font-size: 15px; color: #1e293b; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px; display: flex; align-items: center; gap: 8px;">
                                    <i id="formAdminIcon" class="fas fa-user-plus" style="color: #059669;"></i> <span id="formAdminTitle">Tambah Admin Baru</span>
                                </div>
                                <input type="hidden" id="adminEditId" name="admin_id" value="">
                                <div class="form-group-modal">
                                    <label for="newAdminNama" style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px; color: #475569;">Nama Lengkap</label>
                                    <input type="text" id="newAdminNama" name="nama_lengkap" class="form-input" placeholder="Nama lengkap admin..." required style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box;">
                                </div>
                                <div class="form-group-modal">
                                    <label for="newAdminUsername" style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px; color: #475569;">Username</label>
                                    <input type="text" id="newAdminUsername" name="username" class="form-input" placeholder="Username admin..." required style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box;">
                                </div>
                                <div class="form-group-modal">
                                    <label for="newAdminPassword" id="lblNewAdminPassword" style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px; color: #475569;">Password</label>
                                    <input type="password" id="newAdminPassword" name="password" class="form-input" placeholder="Password admin..." required style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box;">
                                    <small id="helpNewAdminPassword" style="color: #64748b; font-size: 11px; display: none; margin-top: 4px;">Kosongkan jika tidak ingin mengubah password.</small>
                                </div>
                                <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 10px;">
                                    <button type="button" id="btnCancelAdminForm" class="btn btn-secondary" style="padding: 10px 18px; border-radius: 6px; background-color: #94a3b8; border: none; color: white; cursor: pointer;">Kembali</button>
                                    <button type="submit" id="btnSubmitAdminForm" class="btn btn-primary" style="padding: 10px 18px; border-radius: 6px; background-color: #059669; border: none; color: white; cursor: pointer;">Simpan</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="content-area">