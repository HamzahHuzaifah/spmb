                            <i class="fas fa-bars"></i>
                        </button>
                        <div class="topbar-title">
                            <%= typeof title !=='undefined' ? title : 'Dashboard' %>
                        </div>
                    </div>
                    <div class="topbar-right">
                        <div class="user-profile">
                            <span class="user-name">Admin SPMB</span>
