<%- include('partials/header', { title: 'Laporan Utama' , activePage: 'laporan' }) %>

    <div class="filter-bar">
        <form method="GET" action="/laporan" class="filter-form">
            <input type="text" name="search" class="form-control filter-search" placeholder="Cari Uraian / No Trans..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
            <input type="number" class="form-control filter-input-tahun" name="tahun" id="filterTahun" placeholder="Tahun" min="2000" max="2100" value="<%= typeof tahunQuery !== 'undefined' ? tahunQuery : '' %>">
            <select class="form-control filter-select-bulan" name="bulan" id="filterBulan">
                <option value="">Semua Bulan</option>
                <option value="01" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '01') ? 'selected' : '' %>>Januari</option>
                <option value="02" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '02') ? 'selected' : '' %>>Februari</option>
                <option value="03" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '03') ? 'selected' : '' %>>Maret</option>
                <option value="04" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '04') ? 'selected' : '' %>>April</option>
                <option value="05" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '05') ? 'selected' : '' %>>Mei</option>
                <option value="06" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '06') ? 'selected' : '' %>>Juni</option>
                <option value="07" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '07') ? 'selected' : '' %>>Juli</option>
                <option value="08" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '08') ? 'selected' : '' %>>Agustus</option>
                <option value="09" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '09') ? 'selected' : '' %>>September</option>
                <option value="10" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '10') ? 'selected' : '' %>>Oktober</option>
                <option value="11" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '11') ? 'selected' : '' %>>November</option>
                <option value="12" <%= (typeof bulanQuery !== 'undefined' && bulanQuery === '12') ? 'selected' : '' %>>Desember</option>
            </select>
            <button class="btn btn-primary btn-submit-filter" type="submit">Filter</button>
            <a href="/laporan" class="btn btn-secondary btn-reset-filter">Reset</a>
        </form>

        <div class="filter-actions">
            <button type="button" class="btn btn-info btn-preview-laporan" onclick="openModalLaporan()">
                <i class="fas fa-eye"></i> Preview Laporan
            </button>
            <button class="btn btn-secondary btn-print-laporan btn-print" onclick="window.print()">
                <i class="fas fa-print"></i> Cetak / PDF
            </button>
        </div>
    </div>

    <div class="table-container">
        <div class="table-header">
            <div class="table-title">Laporan Keuangan SPMB JIC</div>
        </div>

        <table id="tabelLaporan">
            <thead>
                <tr>
                    <th>No</th>
                    <th>Tanggal</th>
                    <th>Bulan</th>
                    <th>No Transaksi</th>
                    <th>Uraian</th>
                    <th>Pemasukan</th>
                    <th>Pengeluaran</th>
                    <th>Saldo Akhir</th>
                </tr>
            </thead>
            <tbody>
                <%
                function formatDateIndo(dateStr) {
                    if(!dateStr) return '';
                    let d = new Date(dateStr);
                    if(isNaN(d)) return dateStr;
                    let dd = String(d.getDate()).padStart(2, '0');
                    let mm = String(d.getMonth() + 1).padStart(2, '0');
                    let yyyy = d.getFullYear();
                    return `${dd}/${mm}/${yyyy}`;
                }
                
                let saldo = typeof saldoAwalQuery !== 'undefined' ? saldoAwalQuery : 0; 
                let no = ((typeof currentPage !== 'undefined' ? currentPage : 1) - 1) * 10 + 1;
                const monthsList = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];
                %>
                
                <% if ((typeof currentPage === 'undefined' || currentPage === 1) && typeof bulanQuery !== 'undefined' && bulanQuery !== '') { 
                    let selBulanIdx = monthsList.indexOf(bulanQuery);
                    if (selBulanIdx === -1) selBulanIdx = parseInt(bulanQuery) - 1;
                    if (isNaN(selBulanIdx) || selBulanIdx < 0 || selBulanIdx > 11) selBulanIdx = new Date().getMonth();
                    
                    let selTahun = typeof tahunQuery !== 'undefined' && tahunQuery ? parseInt(tahunQuery) : new Date().getFullYear();
                    let prevMonthName = selBulanIdx === 0 ? "Desember" : monthsList[selBulanIdx - 1];
                    let prevMonthYear = selBulanIdx === 0 ? selTahun - 1 : selTahun;
                %>
                <tr>
                    <td><%= no++ %></td>
                    <td>01/<%= String(selBulanIdx + 1).padStart(2, '0') %>/<%= selTahun %></td>
                    <td><%= monthsList[selBulanIdx] %> <%= selTahun %></td>
                    <td>-</td>
                    <td>Saldo Bulan <%= prevMonthName %> <%= prevMonthYear %></td>
                    <td style="color: var(--success);"><%= saldo > 0 ? 'Rp ' + saldo.toLocaleString('id-ID') : (saldo === 0 ? 'Rp 0' : '-') %></td>
                    <td style="color: var(--danger);"><%= saldo < 0 ? 'Rp ' + Math.abs(saldo).toLocaleString('id-ID') : '-' %></td>
                    <td style="font-weight: bold;">Rp <%= saldo.toLocaleString('id-ID') %></td>
                </tr>
                <% } %>

                <% if(laporan && laporan.length > 0) {
                    laporan.forEach((item) => {
                    saldo = saldo + item.pemasukan - item.pengeluaran;
                    %>
                    <tr>
                        <td><%= no++ %></td>
                        <td><%= formatDateIndo(item.tanggal) %></td>
                        <td>
                            <% 
                            const bulanIdx = parseInt(item.bulan) - 1;
                            const namaBulan = (bulanIdx >= 0 && bulanIdx < 12) ? monthsList[bulanIdx] : item.bulan;
                            %>
                            <%= namaBulan %> <%= item.tahun %>
                        </td>
                        <td><%= item.noTransaksi %></td>
                        <td><%= item.uraian %></td>
                        <td style="color: var(--success);">
                            <%= item.pemasukan > 0 ? 'Rp ' + item.pemasukan.toLocaleString('id-ID') : '-' %>
                        </td>
                        <td style="color: var(--danger);">
                            <%= item.pengeluaran > 0 ? 'Rp ' + item.pengeluaran.toLocaleString('id-ID') : '-' %>
                        </td>
                        <td style="font-weight: bold;">Rp <%= saldo.toLocaleString('id-ID') %></td>
                    </tr>
                <% }) } else if ((typeof currentPage !== 'undefined' && currentPage !== 1) || typeof bulanQuery === 'undefined' || !bulanQuery) { %>
                    <tr>
                        <td colspan="8" style="text-align: center;">Tidak ada data laporan</td>
                    </tr>
                <% } %>
            </tbody>
        </table>

        <!-- Pagination UI -->
        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px; padding: 10px 0; border-top: 1px solid #eee;">
                <div style="color: #666; font-size: 14px;">
                    Menampilkan Halaman <strong><%= currentPage %></strong> dari <strong><%= totalPages %></strong> 
                    (Total: <%= totalData %> Data)
                </div>
                <div style="display: flex; gap: 5px;">
                    <% if (currentPage > 1) { %>
                        <a href="?page=<%= currentPage - 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '' %><%= typeof bulanQuery !== 'undefined' && bulanQuery ? '&bulan='+bulanQuery : '' %><%= typeof tahunQuery !== 'undefined' && tahunQuery ? '&tahun='+tahunQuery : '' %>" class="btn btn-secondary" style="padding: 5px 12px; text-decoration: none;">&laquo; Prev</a>
                    <% } %>

                    <% 
                    let startPage = Math.max(1, currentPage - 2);
                    let endPage = Math.min(totalPages, currentPage + 2);
                    for(let i = startPage; i <= endPage; i++) { 
                    %>
                        <a href="?page=<%= i %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '' %><%= typeof bulanQuery !== 'undefined' && bulanQuery ? '&bulan='+bulanQuery : '' %><%= typeof tahunQuery !== 'undefined' && tahunQuery ? '&tahun='+tahunQuery : '' %>" class="btn <%= currentPage === i ? 'btn-primary' : 'btn-secondary' %>" style="padding: 5px 12px; text-decoration: none;">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= currentPage + 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '' %><%= typeof bulanQuery !== 'undefined' && bulanQuery ? '&bulan='+bulanQuery : '' %><%= typeof tahunQuery !== 'undefined' && tahunQuery ? '&tahun='+tahunQuery : '' %>" class="btn btn-secondary" style="padding: 5px 12px; text-decoration: none;">Next &raquo;</a>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <!-- Laporan Modal (Iframe) -->
    <div id="laporanModal" class="modal-overlay" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
        <div class="modal-content" style="background-color: transparent; padding: 0; border-radius: 8px; width: 95%; max-width: 900px; height: 90vh; position: relative; display: flex; flex-direction: column;">
            <div style="background-color: white; padding: 15px; border-radius: 8px 8px 0 0; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee;">
                <h3 style="margin: 0; font-size: 18px;">Preview Laporan</h3>
                <span class="close-modal" onclick="closeModalLaporan()" style="cursor: pointer; font-size: 24px; color: #666; font-weight: bold; line-height: 1;">&times;</span>
            </div>
            <div style="flex: 1; background: #f0f2f5; border-radius: 0 0 8px 8px; overflow: hidden;">
                <iframe id="laporanIframe" src="" style="width: 100%; height: 100%; border: none; border-radius: 0 0 8px 8px;"></iframe>
            </div>
        </div>
    </div>

    <script>
        function openModalLaporan() {
            const filterBulan = document.getElementById("filterBulan").value;
            const filterTahun = document.querySelector('input[name="tahun"]').value || new Date().getFullYear();
            
            if (!filterBulan) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Pemberitahuan',
                    text: 'Silakan pilih Bulan terlebih dahulu untuk melihat preview laporan bulanan.',
                    confirmButtonText: 'OK',
                    confirmButtonColor: '#3a7b5e'
                });
                return;
            }

            document.getElementById('laporanModal').style.display = 'flex';
            document.getElementById('laporanIframe').src = '/laporan-bulanan?bulan=' + filterBulan + '&tahun=' + filterTahun;
        }

        function closeModalLaporan() {
            document.getElementById('laporanModal').style.display = 'none';
            document.getElementById('laporanIframe').src = '';
        }

        function filterData() {
            var filterTahun = document.getElementById("filterTahun").value.toLowerCase();
            var filterBulan = document.getElementById("filterBulan").value.toLowerCase();
            var table = document.getElementById("tabelLaporan");
            var tr = table.getElementsByTagName("tr");

            for (var i = 1; i < tr.length; i++) {
                var tdBulan = tr[i].getElementsByTagName("td")[2]; // Bulan dan Tahun is index 2
                if (tdBulan) {
                    var txtBulan = tdBulan.textContent || tdBulan.innerText;
                    var txtLower = txtBulan.toLowerCase();

                    var matchTahun = filterTahun === "" || txtLower.indexOf(filterTahun) > -1;
                    var matchBulan = filterBulan === "" || txtLower.indexOf(filterBulan) > -1;

                    if (matchTahun && matchBulan) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }
            }
        }
    </script>

    <%- include('partials/footer') %>