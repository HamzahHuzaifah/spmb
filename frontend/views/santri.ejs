<%- include('partials/header', { title: 'Data Santri Baru' , activePage: 'santri' }) %><link rel="stylesheet" href="/css/santri.css">

    <%- include('partials/filter-bar', {
        actionUrl: '/santri',
        searchQuery: typeof searchQuery !== 'undefined' ? searchQuery : '',
        filterType: 'pendidikan',
        pendidikanType: 'filter_baru',
        pendidikanPlaceholder: 'Semua Pendidikan',
        pendidikanQuery: typeof pendidikanQuery !== 'undefined' ? pendidikanQuery : '',
        actionsHtml: `
            <a href="/santri/export-excel?search=${typeof searchQuery !== 'undefined' ? searchQuery : ''}&pendidikan=${typeof pendidikanQuery !== 'undefined' ? pendidikanQuery : ''}" class="btn btn-secondary btn-print" style="text-decoration: none;" download>
                <i class="fas fa-file-excel"></i> Export Excel
            </a>
            <button type="button" class="btn btn-primary" onclick="openAddSantriModal()">
                <i class="fas fa-plus"></i> Tambah Santri
            </button>
            <button type="button" class="btn btn-warning"
                style="background-color: #ffc107; color: #000; border-color: #ffc107;"
                onclick="openAddSantriBeasiswaModal()">
                <i class="fas fa-plus"></i> Tambah Santri Beasiswa
            </button>
        `
    }) %>

    <div class="table-container">
        <div class="table-header">
            <div class="table-title">Master Data Santri</div>
        </div>

        <table id="dataTable">
            <thead>
                <tr>
                    <th>No</th>
                    <th>No. Pendaftaran</th>
                    <th>Timestamp</th>
                    <th>Email</th>
                    <th>Jalur Pendaftaran</th>
                    <th>Nama Santri</th>
                    <th>Jenis Kelamin</th>
                    <th>Pendidikan</th>
                    <th>Usia per Juli</th>
                    <th>Nama Orang Tua</th>
                    <th>No Telepon</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% if(santri && santri.length> 0) { %>
                    <% santri.forEach((item, index)=> { %>
                        <tr>
                            <td>
                                <%= (typeof currentPage !== 'undefined' ? (currentPage - 1) * 10 : 0) + index + 1 %>
                            </td>
                            <td><strong>
                                    <%= item.nomorPendaftaran || '-' %>
                                </strong></td>
                            <td style="font-size: 12px; color: #666;">
                                <%= item.timestamp || '-' %>
                            </td>
                            <td>
                                <%= item.email || '-' %>
                            </td>
                            <td><span
                                    class="badge <%= item.jalurPendaftaran === 'Reguler' ? 'badge-info' : 'badge-warning' %>">
                                    <%= item.jalurPendaftaran || 'Reguler' %>
                                </span></td>
                            <td style="font-weight: 600;">
                                <%= item.nama %>
                            </td>
                            <td>
                                <%= item.jenisKelamin %>
                            </td>
                            <td><span class="badge badge-info">
                                    <%= item.pendidikan %>
                                </span></td>
                            <td>
                                <%= item.usia %> Thn
                            </td>
                            <td>
                                <%= item.namaAyah %>
                            </td>
                            <td>
                                <%= item.teleponAyah %>
                            </td>
                            <td>
                                <%- include('partials/table-actions', {
                                    type: 'santri',
                                    item: item,
                                    detailOnClick: 'openSantriModal(this)',
                                    deleteUrl: '/santri/delete/' + item.id
                                }) %>
                            </td>

                        </tr>
                        <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="11" style="text-align: center;">Belum ada data santri</td>
                                </tr>
                                <% } %>
            </tbody>
        </table>

        <!-- Pagination UI -->
        <%- include('partials/pagination', { 
            currentPage: currentPage, 
            totalPages: totalPages, 
            totalData: totalData, 
            baseUrl: '/santri', 
            queryParams: (typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '') + 
                         (typeof pendidikanQuery !== 'undefined' && pendidikanQuery ? '&pendidikan='+pendidikanQuery : '')
        }) %>
    </div>

    <!-- The Modal -->
    <div id="santriModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 style="color: var(--primary); margin: 0;">Detail Data Santri</h2>
                <div style="display: flex; align-items: center;">
                    <button type="button" class="btn-print" onclick="window.print()"><i class="fas fa-print"></i> Cetak
                        PDF</button>
                    <span class="close-modal" onclick="closeSantriModal()">&times;</span>
                </div>
            </div>

            <form id="editSantriForm" method="POST" action="" onsubmit="handleAjaxSubmitGlobal(event, this)">
                <div class="form-card" style="box-shadow: none; padding: 0;">
                    <!-- A. Data Calon Santri -->
                    <h3 style="margin-bottom: 15px; color: var(--text-main);">A. Data Calon Santri</h3>
                    <div class="modal-grid">

                        <div class="form-group-modal">
                            <label>No. Pendaftaran</label>
                            <input type="text" name="nomorPendaftaran" id="m_nomorPendaftaran" class="form-input"
                                readonly style="background-color: #f5f5f5; border: 1px solid #ddd; color: #666;">
                        </div>
                        <div class="form-group-modal">
                            <label>Email Pendaftar</label>
                            <input type="email" name="email" id="m_email" class="form-input">
                        </div>
                        <div class="form-group-modal">
                            <label>Jalur Pendaftaran</label>
                            <select name="jalurPendaftaran" id="m_jalurPendaftaran" class="form-input">
                                <option value="Reguler">Reguler</option>
                                <option value="Beasiswa Dhuafa">Beasiswa Dhuafa</option>
                                <option value="Beasiswa Yatim/Piatu">Beasiswa Yatim/Piatu</option>
                                <option value="Beasiswa Pekerja/Komunitas di JIC">Beasiswa Pekerja/Komunitas di JIC
                                </option>
                            </select>
                        </div>
                        <div class="form-group-modal">
                            <label>Tingkat Pendidikan</label>
                            <%- include('partials/select-pendidikan', { 
                                type: 'form_baru',
                                name: 'tingkatPendidikan',
                                id: 'm_tingkatPendidikan',
                                className: 'form-input',
                                required: true,
                                placeholder: ''
                            }) %>
                        </div>

                        <%- include('partials/form-data-santri', { 
                            layout: 'flat-grid',
                            idPrefix: 'm_',
                            genderInputType: 'select',
                            nameInputName: 'nama',
                            isReadonly: true
                        }) %>

                    </div>
                    <hr style="border: 0; border-top: 1px dashed var(--border); margin: 30px 0;">

                    <!-- B. Data Orang Tua -->
                    <h3 style="margin-bottom: 15px; color: var(--text-main);">B. Data Orang Tua / Wali</h3>
                    <%- include('partials/form-orang-tua', { 
                        layout: 'grid-rows',
                        idPrefix: 'm_',
                        groupClass: 'form-group-modal',
                        showEmail: false,
                        required: true
                    }) %>

                        <div style="margin-top: 30px; text-align: right; border-top: 1px solid #eee; padding-top: 15px;">
                            <button type="button" class="btn btn-secondary" onclick="closeSantriModal()"
                                style="padding: 10px 25px; border-radius: 6px; border: none; font-weight: bold;">Batal</button>
                            <button type="submit" class="btn btn-primary"
                                style="margin-left: 10px; padding: 10px 25px; border-radius: 6px; border: none; font-weight: bold;">Simpan Perubahan</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>



    <!-- Success Modal -->
    <%- include('partials/success-modal', { modalType: 'baru' }) %>
    <!-- The Add Modal -->
    <div id="addSantriModal" class="modal">
        <div class="modal-content" style="max-width: 850px;">
            <div class="modal-header">
                <h2 style="color: var(--primary); margin: 0;">Form Pendaftaran Santri Baru</h2>
                <div>
                    <button type="button" class="btn btn-warning" onclick="fillTestingDataSantri(false)" style="margin-right: 15px; font-size: 12px; padding: 5px 10px;">Isi Data Testing</button>
                    <span class="close-modal" onclick="closeAddSantriModal()">&times;</span>
                </div>
            </div>

            <form action="/daftar" method="POST" onsubmit="return handleAjaxSubmit(event, this)">

                <h3
                    style="margin-bottom: 15px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px;">
                    A. Data Calon Santri</h3>
                <div class="modal-grid">
                    <div class="form-group-modal">
                        <label class="required">Tingkat Pendidikan yang Didaftar</label>
                        <%- include('partials/select-pendidikan', { 
                            type: 'form_baru',
                            name: 'pendidikan',
                            className: 'form-input',
                            required: true,
                            placeholder: '-- Pilih Satuan Pendidikan --'
                        }) %>
                    </div>

                    <%- include('partials/form-data-santri', { 
                        layout: 'flat-grid'
                    }) %>
                </div>

                <!-- B. Data Orang Tua / Wali -->
                <h3
                    style="margin-bottom: 15px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px; margin-top: 20px;">
                    B. Data Orang Tua / Wali</h3>
                <div class="modal-grid">
                    <%- include('partials/form-orang-tua', { 
                        layout: 'grid',
                        groupClass: 'form-group-modal',
                        showEmail: true,
                        required: true
                    }) %>
                </div>

                <div style="margin-top: 30px; text-align: right; border-top: 1px solid #eee; padding-top: 15px;">
                    <button type="button" class="btn btn-secondary" onclick="closeAddSantriModal()"
                        style="padding: 10px 25px; border-radius: 6px; border: none; font-weight: bold;">Batal</button>
                    <button type="submit" class="btn btn-primary"
                        style="margin-left: 10px; padding: 10px 25px; border-radius: 6px; border: none; font-weight: bold;">Kirim
                        Pendaftaran</button>
                </div>
            </form>
        </div>
    </div>

    <!-- The Add Santri Beasiswa Modal -->
        <div id="addSantriBeasiswaModal" class="modal">
            <div class="modal-content" style="max-width: 850px;">
                <div class="modal-header">
                    <h2 style="color: #d35400; margin: 0;">Form Pendaftaran Santri Baru (Beasiswa)</h2>
                    <div>
                        <button type="button" class="btn btn-warning" onclick="fillTestingDataSantri(true)" style="margin-right: 15px; font-size: 12px; padding: 5px 10px;">Isi Data Testing</button>
                        <span class="close-modal" onclick="closeAddSantriBeasiswaModal()">&times;</span>
                    </div>
                </div>
                <form action="/daftar/beasiswa" method="POST" onsubmit="return handleAjaxSubmit(event, this)">

                    <!-- Pilihan Jalur Beasiswa -->
                    <h3
                        style="margin-bottom: 15px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px;">
                        Jalur Pendaftaran Beasiswa</h3>
                    <div class="form-group-modal" style="margin-bottom: 30px;">
                        <div class="radio-group" style="flex-direction: column; gap: 15px;">
                            <label class="radio-label">
                                <input type="radio" name="jalurBeasiswa" value="Beasiswa Dhuafa" required>
                                <div>
                                    <strong>Beasiswa Dhuafa</strong>
                                    <div class="form-help">Potongan biaya khusus bagi kaum dhuafa (wajib melampirkan
                                        SKTM).</div>
                                </div>
                            </label>
                            <label class="radio-label">
                                <input type="radio" name="jalurBeasiswa" value="Beasiswa Yatim/Piatu">
                                <div>
                                    <strong>Beasiswa Yatim/Piatu</strong>
                                    <div class="form-help">Potongan biaya khusus anak yatim/piatu (wajib melampirkan
                                        Surat
                                        Keterangan/Akta Kematian dan SKTM).</div>
                                </div>
                            </label>
                            <label class="radio-label">
                                <input type="radio" name="jalurBeasiswa" value="Beasiswa Pekerja/Komunitas di JIC">
                                <div>
                                    <strong>Beasiswa Pekerja/Komunitas di JIC</strong>
                                    <div class="form-help">Potongan biaya khusus bagi keluarga pegawai/pjlp/komunitas di
                                        lingkungan
                                        JIC. (wajib melampirkan KTP & KK orang tua serta kartu pegawai/pjlp/komunitas
                                        JIC atau surat
                                        keterangan dari kantor atau komunitas)</div>
                                </div>
                            </label>
                            <label class="radio-label">
                                <input type="radio" name="jalurBeasiswa" value="Beasiswa Satu Keluarga">
                                <div>
                                    <strong>Beasiswa Satu Keluarga</strong>
                                    <div class="form-help">Potongan biaya khusus jika mendaftarkan atau menyekolahkan 2
                                        anak kandung
                                        atau lebih dalam satu keluarga. (wajib melampirkan KTP & KK orang tua)</div>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- A. Data Calon Santri -->
                    <h3
                        style="margin-bottom: 15px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px;">
                        A. Data Calon Santri</h3>
                    <div class="modal-grid">
                        <div class="form-group-modal">
                            <label class="required">Tingkat Pendidikan yang Didaftar</label>
                            <%- include('partials/select-pendidikan', { 
                                type: 'form_baru',
                                name: 'pendidikan',
                                className: 'form-input',
                                required: true,
                                placeholder: '-- Pilih Satuan Pendidikan --'
                            }) %>
                        </div>

                        <%- include('partials/form-data-santri', { 
                            layout: 'flat-grid',
                            genderInputName: 'jenisKelaminBeasiswa'
                        }) %>
                    </div>

                    <!-- B. Data Orang Tua / Wali -->
                    <h3
                        style="margin-bottom: 15px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px; margin-top: 20px;">
                        B. Data Orang Tua / Wali</h3>
                    <div class="modal-grid">
                        <%- include('partials/form-orang-tua', { 
                            layout: 'grid',
                            groupClass: 'form-group-modal',
                            showEmail: true,
                            required: true
                        }) %>
                    </div>

                    <div style="margin-top: 30px; text-align: right; border-top: 1px solid #eee; padding-top: 15px;">
                        <button type="button" class="btn btn-secondary" onclick="closeAddSantriBeasiswaModal()"
                            style="padding: 10px 25px; border-radius: 6px; border: none; font-weight: bold;">Batal</button>
                        <button type="submit" class="btn btn-primary"
                            style="background-color: #d35400; color: white; margin-left: 10px; padding: 10px 25px; border-radius: 6px; border: none; font-weight: bold;">Kirim
                            Pendaftaran Beasiswa</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- PRINT ONLY DETAIL AREA -->
        <div id="printDetailArea" class="print-only">
            <div class="print-kop-surat">
                <img src="/images/Logo%20Madrasah.webp" alt="Logo Madrasah" class="kop-logo-kiri">
                <div class="kop-text">
                    <h1 class="kop-title">PANITIA PENERIMAAN SANTRI BARU (PSB)</h1>
                    <h2 class="kop-subtitle">MADRASAH AL-QUR'AN & MADRASAH DINIYAH</h2>
                    <h2 class="kop-highlight">JAKARTA ISLAMIC CENTRE</h2>
                    <p class="kop-address">Gd. Sosial Budaya Lt. 2, Jl. Kramat Jaya, Tugu Utara, Koja, Jakarta Utara 14260</p>
                    <p class="kop-contact">No. Telp: 0878-8996-9936 / 0857-1406-5288</p>
                </div>
                <img src="/images/madrasahjic.webp" alt="Logo JIC" class="kop-logo-kanan">
            </div>
            <div class="print-divider"></div>
            
            <h2 class="print-document-title">BIODATA PENDAFTARAN CALON SANTRI BARU</h2>
            
            <h3 class="print-section-title">A. DATA CALON SANTRI</h3>
            <table class="print-data-table">
                <tr>
                    <td style="width: 30%;">No. Pendaftaran</td>
                    <td style="width: 3%;">:</td>
                    <td id="p_nomorPendaftaran" style="font-weight: bold;"></td>
                </tr>
                <tr>
                    <td>Tingkat Pendidikan</td>
                    <td>:</td>
                    <td id="p_tingkatPendidikan" style="font-weight: bold;"></td>
                </tr>
                <tr>
                    <td>Jalur Pendaftaran</td>
                    <td>:</td>
                    <td id="p_jalurPendaftaran"></td>
                </tr>
                <tr>
                    <td>Email Pendaftar</td>
                    <td>:</td>
                    <td id="p_email"></td>
                </tr>
                <tr>
                    <td>Nama Lengkap</td>
                    <td>:</td>
                    <td id="p_nama" style="font-weight: bold; text-transform: uppercase;"></td>
                </tr>
                <tr>
                    <td>Nama Panggilan</td>
                    <td>:</td>
                    <td id="p_namaPanggilan"></td>
                </tr>
                <tr>
                    <td>Jenis Kelamin</td>
                    <td>:</td>
                    <td id="p_jenisKelamin"></td>
                </tr>
                <tr>
                    <td>Tempat / Tanggal Lahir</td>
                    <td>:</td>
                    <td id="p_ttl"></td>
                </tr>
                <tr>
                    <td>Agama</td>
                    <td>:</td>
                    <td id="p_agama"></td>
                </tr>
                <tr>
                    <td>Status dalam Keluarga</td>
                    <td>:</td>
                    <td id="p_statusKeluarga"></td>
                </tr>
                <tr>
                    <td>Anak Ke</td>
                    <td>:</td>
                    <td><span id="p_anakKe"></span> dari <span id="p_dariBersaudara"></span> bersaudara</td>
                </tr>
                <tr>
                    <td>Asal Sekolah</td>
                    <td>:</td>
                    <td id="p_asalSekolah"></td>
                </tr>
            </table>
            
            <h3 class="print-section-title">B. DATA ORANG TUA / WALI</h3>
            <table class="print-data-table">
                <tr>
                    <td style="width: 30%;">Nama Ayah</td>
                    <td style="width: 3%;">:</td>
                    <td id="p_namaAyah" style="font-weight: bold;"></td>
                </tr>
                <tr>
                    <td>Pekerjaan Ayah</td>
                    <td>:</td>
                    <td id="p_pekerjaanAyah"></td>
                </tr>
                <tr>
                    <td>No. Telepon Ayah</td>
                    <td>:</td>
                    <td id="p_teleponAyah"></td>
                </tr>
                <tr>
                    <td>Nama Ibu</td>
                    <td>:</td>
                    <td id="p_namaIbu" style="font-weight: bold;"></td>
                </tr>
                <tr>
                    <td>Pekerjaan Ibu</td>
                    <td>:</td>
                    <td id="p_pekerjaanIbu"></td>
                </tr>
                <tr>
                    <td>No. Telepon Ibu</td>
                    <td>:</td>
                    <td id="p_teleponIbu"></td>
                </tr>
                <tr>
                    <td>Alamat Lengkap</td>
                    <td>:</td>
                    <td id="p_alamat"></td>
                </tr>
            </table>
            
            <div class="print-footer-signatures">
                <div class="signature-box" style="float: left;">
                    <p>Mengetahui,</p>
                    <p>Orang Tua / Wali Santri</p>
                    <br><br><br>
                    <p style="font-weight: bold;">( ......................................... )</p>
                </div>
                <div class="signature-box" style="float: right;">
                    <p>Jakarta, <span class="print-current-date"></span></p>
                    <p>Panitia Pendaftaran</p>
                    <br><br><br>
                    <p style="font-weight: bold;">( ......................................... )</p>
                </div>
                <div style="clear: both;"></div>
            </div>
        </div>

        <%- include('partials/footer') %>
<script src="/js/santri.js"></script>