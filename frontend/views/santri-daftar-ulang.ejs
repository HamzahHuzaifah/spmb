<%- include('partials/header', { title: 'Data Santri Daftar Ulang' , activePage: 'santri-daftar-ulang' }) %><link rel="stylesheet" href="/css/santri-daftar-ulang.css">

    <%- include('partials/filter-bar', {
        actionUrl: '/santri-daftar-ulang',
        searchQuery: typeof searchQuery !== 'undefined' ? searchQuery : '',
        filterType: 'pendidikan',
        pendidikanType: 'form_lanjut_ke',
        pendidikanPlaceholder: 'Semua Tujuan Pendidikan',
        pendidikanQuery: typeof pendidikanQuery !== 'undefined' ? pendidikanQuery : '',
        actionsHtml: `
            <a href="/santri-daftar-ulang/export-excel?search=${typeof searchQuery !== 'undefined' ? searchQuery : ''}&pendidikan=${typeof pendidikanQuery !== 'undefined' ? pendidikanQuery : ''}" class="btn btn-secondary btn-print" style="text-decoration: none;" download>
                <i class="fas fa-file-excel"></i> Export Excel
            </a>
            <button type="button" class="btn btn-primary" onclick="document.getElementById('addSantriModal').style.display='block'">
                <i class="fas fa-plus"></i> Tambah Santri
            </button>
        `
    }) %>

    <div class="table-container">
        <div class="table-header">
            <div class="table-title">Master Data Santri Daftar Ulang</div>
        </div>

        <table id="dataTable">
            <thead>
                <tr>
                    <th>No</th>
                    <th>No. Pendaftaran</th>
                    <th>Timestamp</th>
                    <th>Email</th>
                    <th>Jalur Pendaftaran</th>
                    <th>Nama Santri</th>
                    <th>Jenis Kelamin</th>
                    <th>Unit Sebelumnya</th>
                    <th>Lanjut Ke</th>
                    <th>Usia per Juli</th>
                    <th>Nama Orang Tua</th>
                    <th>No Telepon</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% if(santri && santri.length> 0) { %>
                    <% santri.forEach((item, index)=> { %>
                        <tr>
                            <td>
                                <%= (typeof currentPage !== 'undefined' ? (currentPage - 1) * 10 : 0) + index + 1 %>
                            </td>
                            <td><strong>
                                    <%= item.nomorPendaftaran || '-' %>
                                </strong></td>
                            <td style="font-size: 12px; color: #666;">
                                <%= item.timestamp || '-' %>
                            </td>
                            <td>
                                <%= item.email || '-' %>
                            </td>
                            <td><span
                                    class="badge <%= item.jalurPendaftaran === 'Reguler' ? 'badge-info' : 'badge-warning' %>">
                                    <%= item.jalurPendaftaran || 'Reguler' %>
                                </span></td>
                            <td style="font-weight: 600;">
                                <%= item.nama %>
                            </td>
                            <td>
                                <%= item.jenisKelamin %>
                            </td>
                            <td>
                                <%= item.unitSebelumnya %>
                            </td>
                            <td><span class="badge badge-info">
                                    <%= item.lanjutKe %>
                                </span></td>
                            <td>
                                <%= item.usia %> Thn
                            </td>
                            <td>
                                <%= item.namaAyah %>
                            </td>
                            <td>
                                <%= item.teleponAyah %>
                            </td>
                            <td>
                                <%- include('partials/table-actions', {
                                    type: 'santri',
                                    item: item,
                                    detailOnClick: 'openSantriModal(this)',
                                    deleteUrl: '/santri-daftar-ulang/delete/' + item.id
                                }) %>
                            </td>

                        </tr>
                        <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="13" style="text-align: center;">Belum ada data santri daftar ulang</td>
                                </tr>
                                <% } %>
            </tbody>
        </table>

        <!-- Pagination UI -->
        <%- include('partials/pagination', { 
            currentPage: currentPage, 
            totalPages: totalPages, 
            totalData: totalData, 
            baseUrl: '/santri-daftar-ulang', 
            queryParams: (typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '') + 
                         (typeof pendidikanQuery !== 'undefined' && pendidikanQuery ? '&pendidikan='+pendidikanQuery : '')
        }) %>
    </div>
    
    <!-- The Modal -->
    <div id="santriModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 style="color: var(--primary); margin: 0;">Detail Data Santri Daftar Ulang</h2>
                <div style="display: flex; align-items: center;">
                    <button type="button" class="btn-print" onclick="window.print()"><i class="fas fa-print"></i> Cetak
                        PDF</button>
                    <span class="close-modal" onclick="closeSantriModal()">&times;</span>
                </div>
            </div>

            <form id="editSantriForm" method="POST" action="" onsubmit="handleAjaxSubmitGlobal(event, this)">
                <!-- A. Data Calon Santri -->
                <h3
                    style="margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px;">
                    A. Data Calon Santri</h3>

                <div class="form-group" style="display: flex; gap: 20px; margin-bottom: 15px;">
                    <div style="flex: 1;">
                        <label style="display:block; margin-bottom: 5px; font-weight: 500;">No. Pendaftaran</label>
                        <input type="text" name="nomorPendaftaran" id="m_nomorPendaftaran" class="form-input" readonly
                            style="background-color: #f5f5f5; border: 1px solid #ddd; color: #666;">
                    </div>
                    <div style="flex: 1;">
                        <label style="display:block; margin-bottom: 5px; font-weight: 500;">Email Pendaftar</label>
                        <input type="email" name="email" id="m_email" class="form-input">
                    </div>
                </div>

                <div class="form-group" style="display: flex; gap: 20px; margin-bottom: 15px;">
                    <div style="flex: 1;">
                        <label style="display:block; margin-bottom: 5px; font-weight: 500;">Jalur Pendaftaran</label>
                        <select name="jalurPendaftaran" id="m_jalurPendaftaran" class="form-input">
                            <option value="Reguler">Reguler</option>
                            <option value="Beasiswa Dhuafa">Beasiswa Dhuafa</option>
                            <option value="Beasiswa Yatim/Piatu">Beasiswa Yatim/Piatu</option>
                        </select>
                    </div>
                    <div style="flex: 1;">
                        <label style="display:block; margin-bottom: 5px; font-weight: 500;">Unit Sebelumnya</label>
                        <%- include('partials/select-pendidikan', { 
                            type: 'form_unit_sebelumnya',
                            name: 'unitSebelumnya',
                            id: 'm_unitSebelumnya',
                            className: 'form-input',
                            required: true
                        }) %>
                    </div>
                    <div style="flex: 1;">
                        <label style="display:block; margin-bottom: 5px; font-weight: 500;">Tujuan / Lanjut Ke Tingkat</label>
                        <%- include('partials/select-pendidikan', { 
                            type: 'form_lanjut_ke',
                            name: 'lanjutKe',
                            id: 'm_lanjutKe',
                            className: 'form-input',
                            required: true
                        }) %>
                    </div>
                </div>

                <%- include('partials/form-data-santri', { 
                    layout: 'flex-rows',
                    idPrefix: 'm_',
                    genderInputType: 'select',
                    nameInputName: 'nama',
                    isReadonly: true
                }) %>

                <!-- B. Data Orang Tua -->
                <h3
                    style="margin-top: 35px; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px;">
                    B. Data Orang Tua / Wali</h3>

                <%- include('partials/form-orang-tua', { 
                    layout: 'flex-rows',
                    idPrefix: 'm_',
                    groupClass: 'form-group',
                    showEmail: false,
                    required: true
                }) %>

                <div class="modal-footer"
                    style="margin-top: 30px; text-align: right; border-top: 1px solid #eee; padding-top: 15px;">
                    <button type="button" class="btn btn-secondary" onclick="closeSantriModal()">Tutup</button>
                    <button type="submit" class="btn btn-primary" style="margin-left: 10px;">Simpan Perubahan</button>
                </div>
            </form>
        </div>
    </div>


    
    <!-- Success Modal -->
    <%- include('partials/success-modal', { modalType: 'lama' }) %>
    
        <!-- The Add Modal -->
        <div id="addSantriModal" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 style="color: var(--primary); margin: 0;">Tambah Data</h2>
                    <div>
                        <button type="button" class="btn btn-warning" onclick="fillTestingDataDaftarUlang()" style="margin-right: 15px; font-size: 12px; padding: 5px 10px;">Isi Data Testing</button>
                        <span class="close-modal" onclick="document.getElementById('addSantriModal').style.display='none'">&times;</span>
                    </div>
                </div>

                <form action="/daftar-ulang" method="POST" onsubmit="return handleAjaxSubmit(event, this)">
                    
                <h3 style="margin-bottom: 15px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px;">A. Data Calon Santri</h3>
                <div class="modal-grid">
                    <div class="form-group-modal">
                        <label class="required">Jalur Pendaftaran</label>
                        <div class="radio-group" style="display: flex; flex-direction: column; gap: 10px; margin-top: 10px;">
                            <label class="radio-label">
                                <input type="radio" name="jalurPendaftaran" value="Reguler" required> Reguler
                            </label>
                            <label class="radio-label">
                                <input type="radio" name="jalurPendaftaran" value="Beasiswa Dhuafa"> Beasiswa Dhuafa
                            </label>
                            <label class="radio-label">
                                <input type="radio" name="jalurPendaftaran" value="Beasiswa Yatim/Piatu"> Beasiswa Yatim/Piatu
                            </label>
                        </div>
                    </div>

                    <div class="form-group-modal">
                        <label class="required">Unit Sebelumnya</label>
                        <%- include('partials/select-pendidikan', { 
                            type: 'form_unit_sebelumnya',
                            name: 'pendidikanSebelumnya',
                            className: 'form-input',
                            required: true,
                            placeholder: '-- Pilih Tingkat --'
                        }) %>
                    </div>

                    <div class="form-group-modal">
                        <label class="required">Lanjut Ke Tingkat</label>
                        <%- include('partials/select-pendidikan', { 
                            type: 'form_lanjut_ke',
                            name: 'lanjutKe',
                            className: 'form-input',
                            required: true,
                            placeholder: '-- Pilih Tujuan --'
                        }) %>
                    </div>

                    <%- include('partials/form-data-santri', { 
                        layout: 'flat-grid'
                    }) %>
                </div>
    
                    
                <h3 style="margin-bottom: 15px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px; margin-top: 20px;">B. Data Orang Tua / Wali</h3>
                <div class="modal-grid">
                    <%- include('partials/form-orang-tua', { 
                        layout: 'grid',
                        groupClass: 'form-group-modal',
                        showEmail: true,
                        required: true
                    }) %>
                </div>
    

                    <div style="margin-top: 30px; text-align: right; border-top: 1px solid #eee; padding-top: 15px;">
                        <button type="button" class="btn btn-secondary" onclick="document.getElementById('addSantriModal').style.display='none'" style="padding: 10px 25px; border-radius: 6px; border: none; font-weight: bold;">Batal</button>
                        <button type="submit" class="btn btn-primary" style="margin-left: 10px; padding: 10px 25px; border-radius: 6px; border: none; font-weight: bold; background-color: #007bff; color: white;">Simpan Data</button>
                    </div>
                </form>
            </div>
        </div>
        
    
        <!-- PRINT ONLY DETAIL AREA -->
        <div id="printDetailArea" class="print-only">
            <div class="print-kop-surat">
                <img src="/images/Logo%20Madrasah.webp" alt="Logo Madrasah" class="kop-logo-kiri">
                <div class="kop-text">
                    <h1 class="kop-title">PANITIA PENERIMAAN SANTRI BARU (PSB)</h1>
                    <h2 class="kop-subtitle">MADRASAH AL-QUR'AN & MADRASAH DINIYAH</h2>
                    <h2 class="kop-highlight">JAKARTA ISLAMIC CENTRE</h2>
                    <p class="kop-address">Gd. Sosial Budaya Lt. 2, Jl. Kramat Jaya, Tugu Utara, Koja, Jakarta Utara 14260</p>
                    <p class="kop-contact">No. Telp: 0878-8996-9936 / 0857-1406-5288</p>
                </div>
                <img src="/images/madrasahjic.webp" alt="Logo JIC" class="kop-logo-kanan">
            </div>
            <div class="print-divider"></div>
            
            <h2 class="print-document-title">BIODATA PENDAFTARAN ULANG SANTRI</h2>
            
            <h3 class="print-section-title">A. DATA CALON SANTRI</h3>
            <table class="print-data-table">
                <tr>
                    <td style="width: 30%;">No. Pendaftaran</td>
                    <td style="width: 3%;">:</td>
                    <td id="p_nomorPendaftaran" style="font-weight: bold;"></td>
                </tr>
                <tr>
                    <td>Unit Sebelumnya</td>
                    <td>:</td>
                    <td id="p_unitSebelumnya" style="font-weight: bold;"></td>
                </tr>
                <tr>
                    <td>Lanjut Ke</td>
                    <td>:</td>
                    <td id="p_lanjutKe" style="font-weight: bold;"></td>
                </tr>
                <tr>
                    <td>Jalur Pendaftaran</td>
                    <td>:</td>
                    <td id="p_jalurPendaftaran"></td>
                </tr>
                <tr>
                    <td>Email Pendaftar</td>
                    <td>:</td>
                    <td id="p_email"></td>
                </tr>
                <tr>
                    <td>Nama Lengkap</td>
                    <td>:</td>
                    <td id="p_nama" style="font-weight: bold; text-transform: uppercase;"></td>
                </tr>
                <tr>
                    <td>Nama Panggilan</td>
                    <td>:</td>
                    <td id="p_namaPanggilan"></td>
                </tr>
                <tr>
                    <td>Jenis Kelamin</td>
                    <td>:</td>
                    <td id="p_jenisKelamin"></td>
                </tr>
                <tr>
                    <td>Tempat / Tanggal Lahir</td>
                    <td>:</td>
                    <td id="p_ttl"></td>
                </tr>
                <tr>
                    <td>Agama</td>
                    <td>:</td>
                    <td id="p_agama"></td>
                </tr>
                <tr>
                    <td>Status dalam Keluarga</td>
                    <td>:</td>
                    <td id="p_statusKeluarga"></td>
                </tr>
                <tr>
                    <td>Anak Ke</td>
                    <td>:</td>
                    <td><span id="p_anakKe"></span> dari <span id="p_dariBersaudara"></span> bersaudara</td>
                </tr>
                <tr>
                    <td>Asal Sekolah</td>
                    <td>:</td>
                    <td id="p_asalSekolah"></td>
                </tr>
            </table>
            
            <h3 class="print-section-title">B. DATA ORANG TUA / WALI</h3>
            <table class="print-data-table">
                <tr>
                    <td style="width: 30%;">Nama Ayah</td>
                    <td style="width: 3%;">:</td>
                    <td id="p_namaAyah" style="font-weight: bold;"></td>
                </tr>
                <tr>
                    <td>Pekerjaan Ayah</td>
                    <td>:</td>
                    <td id="p_pekerjaanAyah"></td>
                </tr>
                <tr>
                    <td>No. Telepon Ayah</td>
                    <td>:</td>
                    <td id="p_teleponAyah"></td>
                </tr>
                <tr>
                    <td>Nama Ibu</td>
                    <td>:</td>
                    <td id="p_namaIbu" style="font-weight: bold;"></td>
                </tr>
                <tr>
                    <td>Pekerjaan Ibu</td>
                    <td>:</td>
                    <td id="p_pekerjaanIbu"></td>
                </tr>
                <tr>
                    <td>No. Telepon Ibu</td>
                    <td>:</td>
                    <td id="p_teleponIbu"></td>
                </tr>
                <tr>
                    <td>Alamat Lengkap</td>
                    <td>:</td>
                    <td id="p_alamat"></td>
                </tr>
            </table>
            
            <div class="print-footer-signatures">
                <div class="signature-box" style="float: left;">
                    <p>Mengetahui,</p>
                    <p>Orang Tua / Wali Santri</p>
                    <br><br><br>
                    <p style="font-weight: bold;">( ......................................... )</p>
                </div>
                <div class="signature-box" style="float: right;">
                    <p>Jakarta, <span class="print-current-date"></span></p>
                    <p>Panitia Pendaftaran</p>
                    <br><br><br>
                    <p style="font-weight: bold;">( ......................................... )</p>
                </div>
                <div style="clear: both;"></div>
            </div>
        </div>

        <%- include('partials/footer') %>
<script src="/js/santri-daftar-ulang.js"></script>